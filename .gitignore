# =============================================================================
# fips-crypto .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# IDE and Editor files
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# -----------------------------------------------------------------------------
# Claude and AI assistant files
# -----------------------------------------------------------------------------
.claude/
.claude*
.cursorrules
.cursor/
.aider*
.continue/

# -----------------------------------------------------------------------------
# macOS system files
# -----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# -----------------------------------------------------------------------------
# Windows system files
# -----------------------------------------------------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# -----------------------------------------------------------------------------
# Linux system files
# -----------------------------------------------------------------------------
*~
.directory
.Trash-*

# -----------------------------------------------------------------------------
# Build outputs
# -----------------------------------------------------------------------------
dist/
pkg/
pkg-node/
target/
*.wasm
!src/**/*.wasm

# -----------------------------------------------------------------------------
# Node.js / npm
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*
yarn.lock
pnpm-lock.yaml

# npm pack output
*.tgz

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional stylelint cache
.stylelintcache

# Yarn v2+ files
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
.pnp.*

# -----------------------------------------------------------------------------
# TypeScript
# -----------------------------------------------------------------------------
*.tsbuildinfo
*.d.ts.map

# -----------------------------------------------------------------------------
# Rust / Cargo
# -----------------------------------------------------------------------------
target/
Cargo.lock
**/*.rs.bk
*.pdb

# -----------------------------------------------------------------------------
# Testing and Coverage
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
*.lcov
.coverage
htmlcov/
test-results/
junit.xml

# Vitest
.vitest-cache/

# -----------------------------------------------------------------------------
# Environment and secrets
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.crt
secrets/
credentials.json

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log

# -----------------------------------------------------------------------------
# Temporary files
# -----------------------------------------------------------------------------
tmp/
temp/
.tmp/
.temp/
*.tmp
*.temp
*.bak
*.backup

# -----------------------------------------------------------------------------
# Documentation build
# -----------------------------------------------------------------------------
docs/_build/
docs/superpowers/
site/

# -----------------------------------------------------------------------------
# Benchmark results (keep structure, ignore data)
# -----------------------------------------------------------------------------
benchmarks/results/*.json
!benchmarks/results/.gitkeep

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
.cache/
.parcel-cache/
.turbo/
.vercel/
.netlify/
docs/REPO-FINDINGS-2026-03-22.md
